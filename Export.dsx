// define our input/output link names
inputname 0 WITH_KEY;
outputname 0 INSERT;
outputname 1 UPDATE;

initialize {
	// define our control variables
	int8 RowRejected0;
	int8 NullSetVar0;

	// declare our intermediate variables for this section
	string InterVar0_0;
	ustring InterVar0_1;
	int8 InterVar0_2;
	string InterVar0_3;

	// initialise constant values which require conversion
	InterVar0_0 = "Y";
	InterVar0_1 = "9999-12-31";
	InterVar0_2 = 3;
	InterVar0_3 = "N";
}

mainloop {

	// initialise the rejected row variable
	RowRejected0 = 1;

	// evaluate columns (no constraints) for link: INSERT
	INSERT.Passenger_Key = (WITH_KEY.MAX + WITH_KEY.ID);
	INSERT.CURRENT_FLAG = InterVar0_0;
	INSERT.EFFECTIVE_DATE = current_date();
	INSERT.EXPIRY_DATE = date_from_ustring(InterVar0_1);
	writerecord 0;
	RowRejected0 = 0;
	// evaluate constraint and columns for link: UPDATE
	if ((WITH_KEY.change_code == InterVar0_2))
	{
		UPDATE.EXPIRY_DATE = current_date();
		UPDATE.CURRENT_FLAG = InterVar0_3;
		writerecord 1;
		RowRejected0 = 0;
	}
}

finish {
}

