  EFFECTIVE_DATE:not_nullable date=EFFECTIVE_DATE;
  EXPIRY_DATE:nullable date=EXPIRY_DATE;
  CURRENT_FLAG:nullable string=CURRENT_FLAG;
keep
  PASSENGER_ID,FIRST_NAME,LAST_NAME,GENDER,
  DATE_OF_BIRTH,NATIONALITY,PASSPORT_NUMBER,EMAIL,
  PHONE,FF_NUMBER,TIER_ID,TOTAL_MILES,
  JOIN_DATE,Passenger_Key,EFFECTIVE_DATE,EXPIRY_DATE,
  CURRENT_FLAG;
)] 'BEFORE:BEFORE.v'
;

