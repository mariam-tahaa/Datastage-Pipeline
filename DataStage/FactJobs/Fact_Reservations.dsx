         Name "XMLProperties"
         Value "<?xml version='1.0' encoding='UTF-16'?><Properties version='1.1'><Common><Context type='int'>1</Context><Variant type='string'>10</Variant><DescriptorVersion type='string'>1.0</DescriptorVersion><PartitionType type='int'>-1</PartitionType><RCP type='int'>0</RCP></Common><Connection><Server modified='1' type='string'><![CDATA[#Server#]]></Server><Username modified='1' type='string'><![CDATA[#Username#]]></Username><Password modified='1' type='string'><![CDATA[#Password#]]></Password><OSLevelAuthentication type='bool'><![CDATA[0]]></OSLevelAuthentication><Version type='string'><![CDATA[10g]]></Version></Connection><Usage><ReadMode type='int'><![CDATA[0]]></ReadMode><GenerateSQL type='bool'><![CDATA[0]]></GenerateSQL><EnableQuotedIDs type='bool'><![CDATA[0]]></EnableQuotedIDs><SQL><SelectStatement modified='1' type='string'><![CDATA[SELECT\(A)    DP.Passenger_Key,\(A)    DF.Flight_Key,\(A)    DFC.FARE_CLASS_SK,\(A)    DBC.Channel_Key,\(A)    R.Promo_ID,\(A)\(A)    DBOOK.Date_Key as Booking_Date_Key,\(A)    DDEP.Date_Key as Departure_Date_Key,\(A)    DARR.Date_Key as Arrival_Date_Key,\(A)\(A)    R.Reservation_ID,\(A)    T.Seat_Number,\(A)    P.Payment_Method,\(A)    R.Amount_Paid,\(A)    T.Miles_Earned,\(A)    T.Miles_Redeemed,\(A)    R.Is_Upgrade,\(A)    R.Status\(A)\(A)FROM RESERVATIONS R\(A)\(A)JOIN DIMPASSENGER DP\(A)    ON DP.Passenger_ID = R.Passenger_ID\(A)\(A)JOIN DIM_FLIGHT DF\(A)    ON DF.Flight_ID = R.Flight_ID\(A)\(A)JOIN DIM_FARE_CLASS DFC\(A)    ON DFC.FARE_CLASS_ID = R.FARE_CLASS_ID\(A)\(A)JOIN DIM_BOOKING_CHANNEL DBC\(A)    ON DBC.Channel_ID = R.Channel_ID\(A)\(A)JOIN DIM_DATE DBOOK\(A)    ON DBOOK.Full_Date = TO_CHAR(R.Booking_Date,'YYYY-MM-DD')\(A)\(A)JOIN FLIGHTS F\(A)    ON F.Flight_ID = R.Flight_ID\(A)\(A)JOIN DIM_DATE DDEP\(A)    ON DDEP.Full_Date = TO_CHAR(F.Scheduled_Departure,'YYYY-MM-DD')\(A)\(A)JOIN DIM_DATE DARR\(A)    ON DARR.Full_Date = TO_CHAR(F.Scheduled_Arrival,'YYYY-MM-DD')\(A)\(A)LEFT JOIN TICKETS T\(A)    ON T.Reservation_ID = R.Reservation_ID\(A)\(A)LEFT JOIN PAYMENTS P\(A)    ON P.Reservation_ID = R.Reservation_ID;\(A)    \(A)    \(A)    \(A)    \(A)    \(A)]]><ReadFromFileSelect type='bool'><![CDATA[0]]></ReadFromFileSelect><Tables collapsed='1'></Tables><Parameters collapsed='1'></Parameters><Columns collapsed='1'></Columns></SelectStatement></SQL><EnablePartitionedReads collapsed='1' type='bool'><![CDATA[0]]></EnablePartitionedReads><Transaction><IsolationLevel type='int'><![CDATA[0]]></IsolationLevel><RecordCount type='int'><![CDATA[2000]]></RecordCount><EndOfWave type='int'><![CDATA[0]]></EndOfWave></Transaction><Session><ArraySize type='int'><![CDATA[2000]]></ArraySize><PrefetchRowCount type='int'><![CDATA[1]]></PrefetchRowCount><PrefetchMemorySize type='int'><![CDATA[0]]></PrefetchMemorySize><PassLobLocator collapsed='1' type='bool'><![CDATA[0]]></PassLobLocator><BFILEasBLOB type='bool'><![CDATA[0]]></BFILEasBLOB><TreatWarningsAsErrors type='bool'><![CDATA[0]]></TreatWarningsAsErrors><TreatFetchTruncateAsError type='bool'><![CDATA[1]]></TreatFetchTruncateAsError></Session><BeforeAfter collapsed='1' type='bool'><![CDATA[0]]></BeforeAfter><ApplicationFailoverControl collapsed='1' type='bool'><![CDATA[0]]></ApplicationFailoverControl></Usage></Properties >"
