  Miles_Earned:not_nullable decimal[10,0]=Miles_Earned;
  Miles_Redeemed:not_nullable decimal[10,0]=Miles_Redeemed;
keep
  Passenger_Key,Flight_Key,FARE_CLASS_SK,Date_Key,
  Ticket_ID,Reservation_ID,Ticket_Number,Seat_Number,
  Base_Fare_USD,Tax_Amount_USD,Fee_Amount_USD,Discount_Amount_USD,
