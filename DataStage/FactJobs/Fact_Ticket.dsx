}'
   

## General options
[ident('Oracle_Connector_0'); jobmon_ident('Oracle_Connector_0')]
## Outputs
0> [modify (
  Passenger_Key:not_nullable decimal[10,0]=Passenger_Key;
  Flight_Key:not_nullable decimal[10,0]=Flight_Key;
  FARE_CLASS_SK:not_nullable decimal[10,0]=FARE_CLASS_SK;
  Date_Key:not_nullable decimal[10,0]=Date_Key;
  Ticket_ID:not_nullable decimal[10,0]=Ticket_ID;
  Reservation_ID:not_nullable decimal[10,0]=Reservation_ID;
  Ticket_Number:not_nullable ustring[max=30]=Ticket_Number;
  Seat_Number:not_nullable ustring[max=30]=Seat_Number;
  Base_Fare_USD:not_nullable decimal[10,2]=Base_Fare_USD;
  Tax_Amount_USD:not_nullable decimal[10,2]=Tax_Amount_USD;
  Fee_Amount_USD:not_nullable decimal[10,2]=Fee_Amount_USD;
  Discount_Amount_USD:not_nullable decimal[10,2]=Discount_Amount_USD;
